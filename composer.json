{
    "name": "electrictomcat/laravel-google-ads-conversions",
    "description": "Drop-in offline conversion tracking for Laravel: captures GCLIDs from ad clicks, buffers conversions in cache, and uploads them to the Google Ads API.",
    "type": "library",
    "keywords": [
        "laravel",
        "google-ads",
        "adwords",
        "conversion-tracking",
        "offline-conversions",
        "gclid",
        "gbraid",
        "attribution",
        "lead-tracking",
        "ppc",
        "marketing",
        "analytics"
    ],
    "homepage": "https://github.com/electrictomcat/laravel-google-ads-conversions",
    "readme": "README.md",
    "license": "MIT",
    "authors": [
        {
            "name": "Tom Michael",
            "email": "tom@theelectricfamily.com",
            "homepage": "https://github.com/electrictomcat",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/electrictomcat/laravel-google-ads-conversions/issues",
        "source": "https://github.com/electrictomcat/laravel-google-ads-conversions",
        "docs": "https://github.com/electrictomcat/laravel-google-ads-conversions#readme"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/electrictomcat"
        }
    ],
    "require": {
        "php": "^8.3",
        "googleads/google-ads-php": "^33.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^11.1.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "ElectricTomCat\\GoogleAdsConversions\\": "src/",
            "ElectricTomCat\\GoogleAdsConversions\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ElectricTomCat\\GoogleAdsConversions\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ElectricTomCat\\GoogleAdsConversions\\GoogleAdsConversionsServiceProvider"
            ],
            "aliases": {
                "GoogleAdsConversions": "ElectricTomCat\\GoogleAdsConversions\\Facades\\GoogleAdsConversions"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
